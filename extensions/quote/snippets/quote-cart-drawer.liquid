<div class="rq-cart-drawer" id="rq-cart-drawer">
    <div class="rq-cart-header">
        <h3>Quote Cart</h3>
        <button class="rq-cart-close" onclick="window.RqCart.closeCart()" aria-label="Close cart">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M18 6L6 18M6 6l12 12"/>
            </svg>
        </button>
    </div>
    
    <div class="rq-cart-items" id="rq-cart-items-list">
        <!-- Items injected by rq-cart.js -->
    </div>
    
    <div class="rq-cart-footer">
        <button class="rq-submit-btn rq-submit-final" onclick="window.rqOpenQuoteFormFromCart()">
            Request Quote
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
        </button>
    </div>
</div>
<div class="rq-cart-drawer-overlay" onclick="window.RqCart.closeCart()"></div>

<div class="rq-cart-floating-icon" onclick="window.RqCart.openCart()">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4H6zM3 6h18M16 10a4 4 0 01-8 0"/>
    </svg>
    <div class="rq-cart-count" style="display: none;">0</div>
</div>
