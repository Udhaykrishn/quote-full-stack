<div id="rqModal-{{ block_id }}" class="rq-modal" aria-hidden="true" role="dialog">
    <div id="rq-app-root-{{ block_id }}" data-shop="{{ shop.permanent_domain }}" style="display:none;"></div>
    <div class="rq-modal-overlay" onclick="rqCloseModal('{{ block_id }}')"></div>
    <div class="rq-modal-content">
        <button class="rq-modal-close" onclick="rqCloseModal('{{ block_id }}')" aria-label="Close Modal">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M6 6L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </button>

        <div class="rq-form-container">
            <div class="rq-progress-wrapper">
                <div class="rq-progress-steps">
                    <div class="rq-progress-step active" data-step="1">
                        <div class="rq-progress-circle">
                            <span>1</span>
                            <svg class="rq-progress-check" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M20 6L9 17L4 12" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </div>
                        <span class="rq-progress-label">Contact</span>
                    </div>
                    <div class="rq-progress-line"></div>
                    <div class="rq-progress-step" data-step="2">
                        <div class="rq-progress-circle">
                            <span>2</span>
                            <svg class="rq-progress-check" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M20 6L9 17L4 12" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </div>
                        <span class="rq-progress-label">Address</span>
                    </div>
                    <div class="rq-progress-line"></div>
                    <div class="rq-progress-step" data-step="3">
                        <div class="rq-progress-circle">
                            <span>3</span>
                            <svg class="rq-progress-check" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M20 6L9 17L4 12" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </div>
                        <span class="rq-progress-label">Details</span>
                    </div>
                    <div class="rq-progress-line"></div>
                    <div class="rq-progress-step" data-step="4">
                        <div class="rq-progress-circle">
                            <span>4</span>
                            <svg class="rq-progress-check" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M20 6L9 17L4 12" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </div>
                        <span class="rq-progress-label">Review</span>
                    </div>
                </div>
            </div>

            <div class="rq-form-header">
                <h2>Submit Your Quote Request</h2>
                <p>Fill in your details and we'll get back to you shortly</p>
            </div>



            <form id="rq-form-{{ block_id }}" onsubmit="event.preventDefault();" class="rq-form">
                <input type="hidden" name="productId" value="{{ product.id }}">
                <input type="hidden" name="variantId" value="{{ product.selected_or_first_available_variant.id }}">
                <input type="hidden" name="productTitle" value="{{ product.title }}">
                <input type="hidden" name="variantTitle" value="{{ product.selected_or_first_available_variant.title }}">
                <input type="hidden" name="productUrl" value="{{ shop.url }}{{ product.url }}">
                <input type="hidden" name="productImage" value="{{ product.featured_image | image_url: width: 200 }}">
                <input type="hidden" name="price" value="{{ product.selected_or_first_available_variant.price | divided_by: 100.0 }}">

                <div id="rq-step-input-{{ block_id }}">
                    
                    <div class="rq-product-hero">
                        {% if product %}
                        <div class="rq-product-summary">
                            {% if product.featured_image %}
                                <img src="{{ product.featured_image | image_url: width: 80 }}" alt="{{ product.title }}" width="60" height="60">
                            {% endif %}
                            <div class="rq-product-info">
                                <span class="rq-product-title">{{ product.title }}</span>
                                {% unless product.has_only_default_variant %}
                                    <span class="rq-product-variant">{{ product.selected_or_first_available_variant.title }}</span>
                                {% endunless %}
                            </div>
                        </div>
                        {% endif %}
    
                        <div class="rq-quantity-container">
                            <label for="rq-qty-{{ block_id }}">Quantity</label>
                            <div class="rq-qty-control-group">
                                 <button type="button" class="rq-qty-adjust minus" onclick="rqAdjustQty('{{ block_id }}', -1)">
                                    <svg width="12" height="2" viewBox="0 0 12 2" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M0 1H12" stroke="currentColor" stroke-width="2"/></svg>
                                 </button>
                                 <input type="number" name="quantity" id="rq-qty-{{ block_id }}" value="1" min="1" onchange="if(this.value < 1) this.value = 1;">
                                 <button type="button" class="rq-qty-adjust plus" onclick="rqAdjustQty('{{ block_id }}', 1)">
                                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M6 0V12M0 6H12" stroke="currentColor" stroke-width="2"/></svg>
                                 </button>
                            </div>
                        </div>
                    </div>
                    
                    <div id="rq-step-1-{{ block_id }}" class="rq-step active">
                        <div class="rq-form-grid">
                            <div class="rq-input-group">
                                <label>First Name <span class="rq-required">*</span></label>
                                <input type="text" name="firstName" id="rq-fname-{{ block_id }}" required>
                                <span class="rq-error" id="rq-error-fname-{{ block_id }}"></span>
                            </div>
                            <div class="rq-input-group">
                                <label>Last Name <span class="rq-required">*</span></label>
                                <input type="text" name="lastName" id="rq-lname-{{ block_id }}" required>
                                <span class="rq-error" id="rq-error-lname-{{ block_id }}"></span>
                            </div>
                        </div>

                        <div class="rq-input-group">
                            <label>Email Address <span class="rq-required">*</span></label>
                            <div class="rq-input-icon">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                    <polyline points="22,6 12,13 2,6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                                <input type="email" name="email" id="rq-email-{{ block_id }}" required>
                            </div>
                            <span class="rq-error" id="rq-error-email-{{ block_id }}"></span>
                        </div>

                        <div class="rq-input-group">
                            <label>Phone Number <span class="rq-required">*</span></label>
                            <div class="rq-input-icon">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                                <input type="tel" name="phone" id="rq-phone-{{ block_id }}" placeholder="10 digits" maxlength="10" oninput="this.value = this.value.replace(/[^0-9]/g, '');" required>
                            </div>
                            <span class="rq-error" id="rq-error-phone-{{ block_id }}"></span>
                        </div>

                        <button type="button" onclick="rqNextStep('{{ block_id }}', 1)" class="rq-submit-btn">
                            Continue
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </button>
                    </div>

                    <div id="rq-step-2-{{ block_id }}" class="rq-step">
                        <div class="rq-input-group">
                            <label>Address Line 1 <span class="rq-required">*</span></label>
                            <input type="text" name="address1" id="rq-address1-{{ block_id }}" required>
                            <span class="rq-error" id="rq-error-address1-{{ block_id }}"></span>
                        </div>

                        <div class="rq-input-group">
                            <label>Address Line 2</label>
                            <input type="text" name="address2" id="rq-address2-{{ block_id }}">
                        </div>

                        <div class="rq-form-grid">
                            <div class="rq-input-group">
                                <label>City <span class="rq-required">*</span></label>
                                <input type="text" name="city" id="rq-city-{{ block_id }}" required>
                                <span class="rq-error" id="rq-error-city-{{ block_id }}"></span>
                            </div>
                            <div class="rq-input-group">
                                <label>District <span class="rq-required">*</span></label>
                                <input type="text" name="district" id="rq-district-{{ block_id }}" required>
                                <span class="rq-error" id="rq-error-district-{{ block_id }}"></span>
                            </div>
                        </div>

                        <div class="rq-form-grid">
                            <div class="rq-input-group">
                                <label>State <span class="rq-required">*</span></label>
                                <input type="text" name="state" id="rq-state-{{ block_id }}" required>
                                <span class="rq-error" id="rq-error-state-{{ block_id }}"></span>
                            </div>
                            <div class="rq-input-group">
                                <label>Pincode <span class="rq-required">*</span></label>
                                <input type="text" name="pincode" id="rq-pincode-{{ block_id }}" maxlength="6" oninput="this.value = this.value.replace(/[^0-9]/g, '');" required>
                                <span class="rq-error" id="rq-error-pincode-{{ block_id }}"></span>
                            </div>
                        </div>

                        <div class="rq-btn-group">
                            <button type="button" onclick="rqPrevStep('{{ block_id }}', 2)" class="rq-submit-btn rq-back-btn">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M19 12H5M12 19l-7-7 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                                Back
                            </button>
                            <button type="button" onclick="rqNextStep('{{ block_id }}', 2)" class="rq-submit-btn">
                                Continue
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                            </button>
                        </div>
                    </div>

                    <!-- Step 3: Message -->
                    <div id="rq-step-3-{{ block_id }}" class="rq-step">
                        <div class="rq-input-group">
                            <label>Additional Message</label>
                            <textarea name="message" id="rq-message-{{ block_id }}" rows="5" maxlength="500" placeholder="Tell us more about your requirements..."></textarea>
                            <span class="rq-error" id="rq-error-message-{{ block_id }}"></span>
                            <small class="rq-char-count">Max 500 characters</small>
                        </div>

                        <div class="rq-btn-group">
                            <button type="button" onclick="rqPrevStep('{{ block_id }}', 3)" class="rq-submit-btn rq-back-btn">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M19 12H5M12 19l-7-7 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                                Back
                            </button>
                            <button type="button" onclick="rqNextStep('{{ block_id }}', 3)" class="rq-submit-btn">
                                Review Info
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                            </button>
                        </div>
                    </div>

                    <!-- Step 4: Review & Submit -->
                    <div id="rq-step-4-{{ block_id }}" class="rq-step">
                        <div class="rq-review-container">
                            <h3 class="rq-review-main-title">Review Your Details</h3>
                            
                            <div class="rq-review-grid">

                                <!-- Contact Section -->
                                <div class="rq-review-card">
                                    <div class="rq-card-header">
                                        <div class="rq-card-icon">
                                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                                <circle cx="12" cy="7" r="4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                            </svg>
                                        </div>
                                        <h4>Contact Info</h4>
                                    </div>
                                    <div class="rq-card-content">
                                        <p id="rq-review-contact-{{ block_id }}" class="rq-review-text"></p>
                                    </div>
                                </div>

                                <!-- Address Section -->
                                <div class="rq-review-card">
                                    <div class="rq-card-header">
                                        <div class="rq-card-icon">
                                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                                <circle cx="12" cy="10" r="3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                            </svg>
                                        </div>
                                        <h4>Shipping Address</h4>
                                    </div>
                                    <div class="rq-card-content">
                                        <p id="rq-review-address-{{ block_id }}" class="rq-review-text"></p>
                                    </div>
                                </div>

                                <!-- Message Section -->
                                <div class="rq-review-card">
                                    <div class="rq-card-header">
                                        <div class="rq-card-icon">
                                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                            </svg>
                                        </div>
                                        <h4>Additional Message</h4>
                                    </div>
                                    <div class="rq-card-content">
                                        <p id="rq-review-message-{{ block_id }}" class="rq-review-text"></p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="rq-btn-group">
                            <button type="button" onclick="rqPrevStep('{{ block_id }}', 4)" class="rq-submit-btn rq-back-btn">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M19 12H5M12 19l-7-7 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                                Back
                            </button>
                            <button type="button" onclick="rqValidateAndSubmit('{{ block_id }}')" class="rq-submit-btn rq-submit-final">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                    <polyline points="22 4 12 14.01 9 11.01" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                                Submit Quote
                            </button>
                        </div>
                    </div>
                </div>

                <div id="rq-step-success-{{ block_id }}" class="rq-success-screen">
                    <div class="rq-success-icon">
                        <svg width="80" height="80" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <circle cx="12" cy="12" r="10" stroke="#10b981" stroke-width="2"/>
                            <path d="M9 12l2 2 4-4" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </div>
                    <h2>Quote Requested Successfully!</h2>
                    <p>Thank you for your request. Our team will review your quote and get back to you shortly.</p>
                    <button type="button" onclick="rqResetAndClose('{{ block_id }}')" class="rq-submit-btn">
                        Continue Shopping
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
