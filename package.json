{
    "name": "merchant-full-stack",
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "@shopify/cli": "^3.0.0"
    },
    "license": "UNLICENSED",
    "private": true,
    "scripts": {
        "build:frontend": "cd frontend && bun run build",
        "shopify": "shopify",
        "dev": "shopify app dev",
        "dev:backend": "bun run --filter backend-express dev",
        "dev:frontend": "cd frontend && bun run dev",
        "test": "bun run --filter backend-express test",
        "build": "bun run build:frontend && shopify app build",
        "deploy": "bun run build:frontend && shopify app deploy"
    },
    "workspaces": [
        "backend-express",
        "frontend"
    ]
}